generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model OptimizationSnapshot {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  
  // We use String for SQLite JSON compatibility (Prisma handles serialization usually, 
  // but explicit String is safer if we want to control parsing manually or if Json type issues arise)
  // Actually, let's try native Json if supported, otherwise String. 
  // For SQLite, Prisma implies Json is supported.
  
  fleetData       String // JSON content of FleetOverview
  optimizationData String // JSON content of OptimizationSummary
  weatherData     String // JSON content of WeatherSummary
  kpiData         String // JSON content of DashboardKPIs
  
  status String // "optimized", "failed", etc.

  // Link to relational analytics data (Optional 1:1 relation)
  runDetails OptimizationRun?
}

model OptimizationRun {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  snapshotId String @unique
  snapshot   OptimizationSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  // Aggregated Metrics
  totalDistanceMeters Int
  totalDurationSeconds Int
  totalJobs           Int
  utilityScore        Float? // Placeholder for an efficiency score

  // Relations
  vehicleMetrics VehicleMetric[]
}

model VehicleMetric {
  id        String   @id @default(uuid())
  
  runId     String
  run       OptimizationRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  vehicleId String // The identifier used in the fleet/optimization
  vehicleType String
  
  // Metrics
  totalDistanceMeters Int
  totalDurationSeconds Int
  jobsAssigned        Int
  efficiencyFactor    Float? // Custom metric (e.g., loaded distance / total distance)
}
